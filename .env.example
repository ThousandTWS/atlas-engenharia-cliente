VITE_RECAPTCHA_SITE_KEY=sua_chave_publica_do_google_recaptcha

# ADS source: backend | n8n
VITE_ADS_DATA_SOURCE=backend

# N8N integration (used when VITE_ADS_DATA_SOURCE=n8n)
VITE_N8N_ADS_BASE_URL=
VITE_N8N_ADS_ENDPOINT_PERFORMANCE=/google-ads/performance
VITE_N8N_ADS_ENDPOINT_CAMPAIGNS=/google-ads/campaigns
VITE_N8N_ADS_ENDPOINT_INSIGHTS=/google-ads/insights
VITE_N8N_ADS_ENDPOINT_CHAT=/google-ads/chat

# Optional full URLs (override base + endpoints)
VITE_N8N_ADS_PERFORMANCE_URL=
VITE_N8N_ADS_CAMPAIGNS_URL=
VITE_N8N_ADS_INSIGHTS_URL=
VITE_N8N_ADS_CHAT_URL=
VITE_N8N_AI_CHAT_URL=

# Auth: none | bearer | api_key
VITE_N8N_ADS_AUTH_TYPE=none
VITE_N8N_ADS_BEARER_TOKEN=
VITE_N8N_ADS_API_KEY=
VITE_N8N_ADS_API_KEY_HEADER=x-api-key

# Realtime (optional WebSocket endpoint)
VITE_REALTIME_WS_URL=

# Gemini direct API fallback (used when n8n chat endpoint is unavailable)
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash
VITE_GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
